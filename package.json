{
  "name": "elevanda-school-client-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"set DISABLE_FRONTEND_SPAWN=1&& npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix backend run start",
    "prisma:migrate": "npm --prefix backend run prisma:migrate",
    "prisma:generate": "npm --prefix backend run prisma:generate"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
